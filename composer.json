{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0.1",
        "jeroen-g/autowire": "dev-main",
        "jeroen-g/explorer": "dev-master",
        "elasticsearch/elasticsearch": "^9.0",
        "laravel/ai": "^0.4.1",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/scout": "^11.0",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^13.0",
        "spatie/laravel-ignition": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": {
        "jeroen-g/autowire": {
            "type": "path",
            "url": "./packages/JeroenG/Autowire",
            "options": {
                "symlink": true
            }
        },
        "jeroen-g/explorer": {
            "type": "path",
            "url": "./packages/JeroenG/Explorer",
            "options": {
                "symlink": true
            }
        }
    }
}
